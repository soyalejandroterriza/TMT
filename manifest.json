{
  "manifest_version": 3,
  "name": "NG CPT",
  "version": "1.0",
  "description": "NG Cherrypicking tool --- Pulsa Ctrl + Shift + Espacio en una página de orden de NG para habilitar.",

  "permissions": ["activeTab", "scripting"],

  "background": {
    "service_worker": "background.js"
  },

  "commands": {
    "toggle-barra": {
      "suggested_key": {
        "default": "Ctrl+Shift+Space"
      },
      "description": "Mostrar / Ocultar barra"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "icons": {
    "16": "16.png",
    "48": "48.png",
    "128": "128.png"
  },

  "action": {
    "default_icon": {
      "16": "16.png",
      "48": "48.png",
      "128": "128.png"
    },
    "default_title": "NG CPT — Mostrar barra" 
  }
}
